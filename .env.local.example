# ──────────────────────────────────────────────────────────────────────────────
# Digital Tech Prosperity — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# Resend API key (https://resend.com → API Keys → Create key)
# Required for contact form and newsletter emails to work.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
# Defaults to info@digitaltechs.in if not set
CONTACT_TO_EMAIL=info@digitaltechs.in

# Google Analytics Measurement ID (optional)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
